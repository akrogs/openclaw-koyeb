# Secretos de OpenClaw en Koyeb.
# Copia este archivo a .env para desarrollo local, o configura estas variables
# como Secrets en el panel de Koyeb. NO commitees el .env real (esta en .gitignore).

# API key de OpenRouter -> https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# Token del gateway para autorizar dispositivos. Genera uno largo y aleatorio:
#   openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=
