# Secretos de OpenClaw en Koyeb.
# Configura estas variables como Secrets en el panel de Koyeb (o copia a .env en local).
# NO commitees el .env real (esta en .gitignore).

# Claves de los proveedores: un agente por proveedor -> cuotas de rate limit independientes.
GEMINI_API_KEY=        # Google AI Studio -> https://aistudio.google.com   (orquestador)
GROQ_API_KEY=          # Groq             -> https://console.groq.com      (tecnico)
CEREBRAS_API_KEY=      # Cerebras         -> https://cloud.cerebras.ai     (formato)

# Token del gateway para autorizar dispositivos. Genera uno largo y aleatorio:
#   openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=

# Opcional: salta la verificacion de modelos al arrancar (preflight).
# SKIP_MODEL_PREFLIGHT=1
