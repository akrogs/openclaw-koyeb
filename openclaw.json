{
  "gateway": {
    "mode": "local",
    "bind": "lan",
    "port": 18789,
    "controlUi": {
      "dangerouslyDisableDeviceAuth": true,
      "allowInsecureAuth": true,
      "allowedOrigins": [
        "http://localhost:18789",
        "http://127.0.0.1:18789",
        "http://35.253.104.10:18789",
        "https://instance-20260620-052154.tail507211.ts.net"
      ]
    }
  },
  "tools": {
    "web": {
      "search": { "provider": "duckduckgo" }
    }
  },
  "plugins": {
    "entries": {
      "browser": { "enabled": false },
      "canvas": { "enabled": false },
      "talk-voice": { "enabled": false },
      "phone-control": { "enabled": false }
    }
  },
  "models": {
    "providers": {
      "cerebras": {
        "baseUrl": "https://api.cerebras.ai/v1",
        "apiKey": "${CEREBRAS_API_KEY}",
        "api": "openai-completions",
        "models": [
          { "id": "gpt-oss-120b", "name": "GPT-OSS 120B (Cerebras)", "contextWindow": 131072, "maxTokens": 32768 },
          { "id": "zai-glm-4.7", "name": "GLM 4.7 (Cerebras)", "contextWindow": 131072, "maxTokens": 16384 }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "workspace": "~/.openclaw/workspaces/shared",
      "thinkingDefault": "low",
      "memorySearch": {
        "provider": "gemini",
        "model": "gemini-embedding-001",
        "outputDimensionality": 768
      }
    },
    "list": [
      {
        "id": "orquestador",
        "default": true,
        "name": "Orquestador (Gemini 2.5 Flash)",
        "workspace": "~/.openclaw/workspaces/orquestador",
        "model": {
          "primary": "google/gemini-2.5-flash",
          "fallbacks": ["google/gemini-3.1-flash-lite", "openrouter/openrouter/free"]
        },
        "thinkingDefault": "high",
        "contextLimits": { "memoryGetMaxChars": 24000 },
        "tools": { "allow": ["read", "write", "edit", "apply_patch", "sessions_spawn", "sessions_yield", "sessions_history", "sessions_list", "session_status", "subagents", "agents_list", "update_plan", "web_search", "web_fetch", "memory_get", "memory_search", "cron", "message", "create_goal", "get_goal", "update_goal", "klavis__*", "klavis__discover_server_categories_or_actions", "klavis__execute_action", "klavis__get_action_details", "klavis__get_category_actions", "klavis__handle_auth_failure", "klavis__search_documentation"] },
        "subagents": { "allowAgents": ["tecnico", "formato"], "requireAgentId": false }
      },
      {
        "id": "tecnico",
        "name": "Tareas Tecnicas (Cerebras GPT-OSS 120B)",
        "workspace": "~/.openclaw/workspaces/tecnico",
        "model": {
          "primary": "cerebras/gpt-oss-120b",
          "fallbacks": ["cerebras/zai-glm-4.7", "openrouter/openrouter/free"]
        },
        "thinkingDefault": "medium",
        "tools": { "profile": "coding", "allow": ["read", "write", "edit", "web_search", "web_fetch"], "deny": ["browser"] },
        "sandbox": { "mode": "off" },
        "subagents": { "allowAgents": ["orquestador"] }
      },
      {
        "id": "formato",
        "name": "Formateo y Resumen (Cerebras GLM 4.7)",
        "workspace": "~/.openclaw/workspaces/formato",
        "model": {
          "primary": "cerebras/zai-glm-4.7",
          "fallbacks": ["cerebras/gpt-oss-120b", "openrouter/openrouter/free"]
        },
        "thinkingDefault": "low",
        "tools": { "allow": ["read", "write"], "deny": ["exec", "browser"] },
        "subagents": { "allowAgents": ["orquestador"] }
      }
    ]
  },
  "session": {
    "agentToAgent": { "maxPingPongTurns": 8 }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "dmPolicy": "allowlist",
      "allowFrom": ["${TELEGRAM_ALLOW_FROM}"]
    }
  },
  "bindings": [
    { "agentId": "orquestador", "match": { "channel": "telegram", "accountId": "default" } }
  ],
  "mcp": {
    "servers": {
      "klavis": {
        "transport": "streamable-http",
        "url": "${KLAVIS_STRATA_URL}",
        "headers": { "Authorization": "Bearer ${KLAVIS_API_KEY}" }
      }
    }
  }
}
