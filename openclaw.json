{
  "models": {
    "providers": {
      "cerebras": {
        "baseUrl": "https://api.cerebras.ai/v1",
        "apiKey": "${CEREBRAS_API_KEY}",
        "api": "openai-completions",
        "models": [
          { "id": "llama-3.3-70b", "name": "Llama 3.3 70B (Cerebras)", "contextWindow": 65536, "maxTokens": 8192 },
          { "id": "qwen-3-coder-480b", "name": "Qwen3 Coder 480B (Cerebras)", "contextWindow": 131072, "maxTokens": 16384 }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "workspace": "~/.openclaw/workspaces/shared",
      "thinkingDefault": "low"
    },
    "list": [
      {
        "id": "orquestador",
        "default": true,
        "name": "Orquestador (Gemini 2.5 Flash)",
        "workspace": "~/.openclaw/workspaces/orquestador",
        "model": {
          "primary": "google/gemini-2.5-flash",
          "fallbacks": ["google/gemini-3.1-flash-lite"]
        },
        "thinkingDefault": "high",
        "contextLimits": { "memoryGetMaxChars": 24000 },
        "tools": { "allow": ["read", "write", "sessions_spawn"] },
        "subagents": { "allowAgents": ["tecnico", "formato"], "requireAgentId": false }
      },
      {
        "id": "tecnico",
        "name": "Tareas Tecnicas (Cerebras)",
        "workspace": "~/.openclaw/workspaces/tecnico",
        "model": {
          "primary": "cerebras/llama-3.3-70b",
          "fallbacks": ["cerebras/qwen-3-coder-480b"]
        },
        "thinkingDefault": "medium",
        "tools": { "profile": "coding", "allow": ["read", "write", "edit"], "deny": ["browser"] },
        "sandbox": { "mode": "off" },
        "subagents": { "allowAgents": ["orquestador"] }
      },
      {
        "id": "formato",
        "name": "Formateo y Resumen (Cerebras Llama 3.3 70B)",
        "workspace": "~/.openclaw/workspaces/formato",
        "model": {
          "primary": "cerebras/llama-3.3-70b",
          "fallbacks": ["cerebras/qwen-3-coder-480b"]
        },
        "thinkingDefault": "low",
        "tools": { "allow": ["read", "write"], "deny": ["exec", "browser"] },
        "subagents": { "allowAgents": ["orquestador"] }
      }
    ]
  },
  "session": {
    "agentToAgent": { "maxPingPongTurns": 8 }
  }
}
